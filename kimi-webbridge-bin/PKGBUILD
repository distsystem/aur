# Maintainer: fecet <xiezej@gmail.com>
pkgname=kimi-webbridge-bin
_pkgname=kimi-webbridge
pkgver=1.9.14
pkgrel=1
pkgdesc="Moonshot Kimi WebBridge daemon — local HTTP bridge between AI agent runtimes and a browser extension"
arch=('x86_64' 'aarch64')
url="https://kimi-webbridge.moonshot.cn"
license=('custom:unknown')
provides=("${_pkgname}=${pkgver}")
conflicts=("${_pkgname}")
install=${_pkgname}.install

_dlbase="https://kimi-web-img.moonshot.cn/webbridge"
source=("${_pkgname}.service")
source_x86_64=("${_pkgname}-${pkgver}-x86_64::${_dlbase}/v${pkgver}/releases/kimi-webbridge-linux-amd64")
source_aarch64=("${_pkgname}-${pkgver}-aarch64::${_dlbase}/v${pkgver}/releases/kimi-webbridge-linux-arm64")
sha256sums=('c3aafe5840029f5940a1ea08db4430eea85eb4c6b3b8745c63728e201fa521af')
sha256sums_x86_64=('119f9cd675b68984f87ecbd6ae7d6e0a3ad4290977a110fe534f28b6eaa19d9c')
sha256sums_aarch64=('5a4e53c5cbdf4fb9ad2cb6f703a34c37f30abe37c442a1ed998c43ad7c1eb41c')

package() {
    install -Dm755 "${srcdir}/${_pkgname}-${pkgver}-${CARCH}" "${pkgdir}/usr/bin/${_pkgname}"
    install -Dm644 "${srcdir}/${_pkgname}.service" "${pkgdir}/usr/lib/systemd/user/${_pkgname}.service"
}
