[Trigger]
Operation = Install
Operation = Upgrade
Type = Path
Target = usr/share/alsa/ucm2/sof-soundwire/sof-soundwire.conf
Target = usr/share/alsa/ucm2/sof-soundwire/rt721.conf

[Action]
Description = Re-patching sof-soundwire UCM for ASUS ProArt PX13 quirks...
When = PostTransaction
Exec = /usr/share/asus-proart-px13-quirks/patch-ucm.sh
