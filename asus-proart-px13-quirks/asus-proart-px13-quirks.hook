[Trigger]
Operation = Install
Operation = Upgrade
Type = Path
Target = usr/share/alsa/ucm2/sof-soundwire/sof-soundwire.conf

[Action]
Description = Re-patching sof-soundwire.conf for tas2783 codec (asus-proart-px13-quirks)...
When = PostTransaction
Exec = /usr/share/asus-proart-px13-quirks/patch-ucm.sh
